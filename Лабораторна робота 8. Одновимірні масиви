//Лабораторна робота 8. Одновимірні масиви

#include <iostream>
using namespace std;

int main()
{
    const int n = 10;
    int a[n];
    bool Palindrome = true;

    cout << "Enter 10 elements of the array:\n";
    for (int i = 0; i < n; i++)
    {
        cout << "a[" << i << "] = ";
        cin >> a[i];
    }

    for (int i = 0; i < n / 2; i++)
    {
        if (a[i] != a[n - 1 - i])
        {
            Palindrome = false;
            break;
        }
    }

    if (Palindrome == true)
    {
        cout << "The array is a palindrome." << endl;
    }
    else
    {
        cout << "The array is NOT a palindrome." << endl;
    }

    return 0;
}
