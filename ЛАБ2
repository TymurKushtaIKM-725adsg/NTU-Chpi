#include <iostream>
using namespace std;

int main()
{
    int a, b;
    cout << "Enter range [a, b]: ";
    cin >> a >> b;
    int maxNum = 0;
    int maxSum = -1;
    for (int i = a; i <= b; i++) {
        int currentSum = 0;
        for (int j = 1; j <= i; j++) {
            if (i % j == 0) {
                currentSum = currentSum + j;
            }
        }
        if (currentSum >= maxSum) {
            maxSum = currentSum;
            maxNum = i;
        }
    }
    cout << "Max number with max sum of divisors: " << maxNum << endl;
    cout << "(Sum: " << maxSum << ")" << endl;
    return 0;
}
