/*
ЗАВДАННЯ 1 : Ввести значення 2-х дійсних змінних а і b. Направити два покажчика на ці змінні
За допомогою покажчика збільшити значення змінної а в 2 рази, а b зменшити в 2 рази.
*/

#include <iostream>
using namespace std;
int main()
{
    float a, b;
    float* pa, * pb;

    pa = &a;
    pb = &b;

    cout << "Enter real number a: ";
    cin >> a;
    cout << "Enter real number b: ";
    cin >> b;

    *pa = *pa * 2;
    *pb = *pb / 2;

    cout << "Value of a after multiplying by 2 = " << *pa << endl;
    cout << "Value of b after dividing by 2 = " << *pb << endl;

    return 0;
}



/*
ЗАВДАННЯ 2 : Описати 3 покажчика на цілий тип. Виділити для них динамічну пам'ять.
Присвоїти довільні значення в виділені комірки пам’яті за допомогою оператора присвоювання.
Поміняти місцями значення перших 2 - х змінних.
*/

#include <iostream>
using namespace std;
int main()
{
    int* p1, * p2, * p3;

    p1 = new int;
    p2 = new int;
    p3 = new int;

    *p1 = 34;
    *p2 = 42;
    *p3 = 76;

    cout << "Before swapping:" << endl;
    cout << "Value 1: " << *p1 << endl;
    cout << "Value 2: " << *p2 << endl;
    cout << "Value 3: " << *p3 << "\n" << endl;

    int temp = *p1;
    *p1 = *p2;
    *p2 = temp;

    cout << "After swapping the first two variables:" << endl;
    cout << "Value 1: " << *p1 << endl;
    cout << "Value 2: " << *p2 << endl;
    cout << "Value 3: " << *p3 << endl;

    delete p1;
    delete p2;
    delete p3;

    return 0;
}



/*
ЗАВДАННЯ 3 : Створити динамічні масиви, використовуючи покажчики. Задано одновимірний масив а[n].
Знайти номер останнього від’ємного елемента і переставити його з першим елементом масиву.
Знайти кількість і суму додатних елементів масиву. 
*/

#include <iostream>
using namespace std;
int main()
{
    srand(time(NULL));

    int SIZE;
    cout << "Enter the size of the array (SIZE): ";
    cin >> SIZE;

    if (SIZE <= 0)
    {
        cout << "Array size must be greater than 0." << endl;
        return 1;
    }

    int* a = new int[SIZE];

    cout << "Original array:" << endl;
    for (int i = 0; i < SIZE; i++)
    {
        a[i] = rand() % 31 - 15;
        cout << a[i] << " ";
    }
    cout << endl;

    int lastNegIndex = -1;

    for (int i = SIZE - 1; i >= 0; i--)
    {
        if (a[i] < 0)
        {
            lastNegIndex = i;
            break;
        }
    }

    if (lastNegIndex != -1)
    {
        int temp = a[0];
        a[0] = a[lastNegIndex];
        a[lastNegIndex] = temp;
        cout << "Swapped first element with the last negative element (index " << lastNegIndex << ")." << endl;
    }
    else
    {
        cout << "No negative elements found to swap." << endl;
    }

    cout << "Array after swap:" << endl;
    for (int i = 0; i < SIZE; i++)
    {
        cout << a[i] << " ";
    }
    cout << endl;

    int posCount = 0;
    int posSum = 0;

    for (int i = 0; i < SIZE; i++)
    {
        if (a[i] > 0)
        {
            posCount++;
            posSum += a[i];
        }
    }

    cout << "Count of positive elements: " << posCount << endl;
    cout << "Sum of positive elements: " << posSum << endl;

    delete[] a;
    return 0;
}
