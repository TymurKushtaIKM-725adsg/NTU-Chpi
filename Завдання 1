//Оператори if/switch. Цикли while/for. Варіант 2. Завдання 1

#include <iostream>
using namespace std;

int main()
{
    int n;
    cout << "Enter an integer n: ";
    cin >> n;

    // Перша перевірка
    if (n % 2 == 0)
    {
        // Друга перевірка
        if ((n >= 10 && n <= 99) || (n <= -10 && n >= -99))
        {
            cout << "The entered number is an even two-digit number." << endl;
        }
        else
        {
            cout << "The entered number is NOT an even two-digit number." << endl;
        }
    }
    else
    {
        cout << "The entered number is NOT an even two-digit number." << endl;
    }

    return 0;
}
