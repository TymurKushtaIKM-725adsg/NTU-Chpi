//Оператори if/switch. Цикли while/for. Варіант 2. Завдання 2.

#include <iostream>
using namespace std;

int main()
{
    int n;
    cout << "Enter the number of Fibonacci numbers: ";
    cin >> n;


    int a = 0;
    int b = 1;
    int c = 0;

    cout << "The first " << n << " Fibonacci numbers are: ";

    while (c < n)
    {
        cout << a << " ";
        int d = a + b;
        a = b;
        b = d;
        c++;
    }

    cout << endl;

    return 0;
}
